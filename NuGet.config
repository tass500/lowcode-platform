<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-local NuGet sources.

    This project only uses public packages. A user-level/private feed (e.g. ProGet)
    can break restore in fresh/dev environments (403/unauthorized). Keeping sources
    explicit here makes builds deterministic.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>

