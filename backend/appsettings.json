{
  "Api": {
    "PublicVersion": "1"
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 10485760
    }
  },
  "RateLimiting": {
    "PermitLimit": 400,
    "WindowSeconds": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Bff": {
      "Enabled": false,
      "AllowNonDevelopment": false
    }
  }
}
